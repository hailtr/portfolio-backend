---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchProfile } from '../lib/api';
import { getLocale, t } from '../lib/i18n';

const locale = getLocale(Astro.currentLocale);
const profile = await fetchProfile(locale);
---

<BaseLayout
  title={`${t('contact.title', locale)} — Rafael Ortiz`}
  description={locale === 'es'
    ? 'Contacta a Rafael Ortiz — Senior Data Engineer'
    : 'Contact Rafael Ortiz — Senior Data Engineer'}
>
  <section class="relative overflow-hidden pt-32 pb-20 md:pt-40">
    <!-- Glow -->
    <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-[var(--color-accent)] opacity-[0.03] blur-[120px]" />

    <div class="relative mx-auto max-w-lg px-[var(--container-px)]">
      <div class="text-center">
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
          {t('contact.cta', locale)}
        </h1>
        <p class="mt-4 text-[var(--color-fg-muted)] leading-relaxed">
          {locale === 'es'
            ? 'Disponible para contratos, roles senior/lead, y consultoría en plataformas de datos.'
            : 'Available for contracts, senior/lead roles, and data platform consulting.'}
        </p>
      </div>

      <div class="mt-12 space-y-4">
        <!-- Email CTA -->
        <a
          href={`mailto:${profile.email}`}
          class="card group flex items-center gap-4 px-6 py-5"
        >
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[var(--color-accent-soft)] transition-colors group-hover:bg-[var(--color-accent)]/20">
            <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-faint)]">Email</p>
            <p class="mt-0.5 font-semibold transition-colors group-hover:text-[var(--color-accent)]">{profile.email}</p>
          </div>
        </a>

        <!-- Social links -->
        <div class="grid gap-3 grid-cols-2">
          {profile.social.github && (
            <a
              href={profile.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="card group flex items-center justify-center gap-2.5 px-4 py-4 text-sm font-medium text-[var(--color-fg-muted)] hover:text-[var(--color-accent)]"
            >
              <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          )}
          {profile.social.linkedin && (
            <a
              href={profile.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="card group flex items-center justify-center gap-2.5 px-4 py-4 text-sm font-medium text-[var(--color-fg-muted)] hover:text-[var(--color-accent)]"
            >
              <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          )}
          <a
            href="https://www.upwork.com/freelancers/~01b72c2ac497639f74"
            target="_blank"
            rel="noopener noreferrer"
            class="card group flex items-center justify-center gap-2.5 px-4 py-4 text-sm font-medium text-[var(--color-fg-muted)] hover:text-[var(--color-accent)]"
          >
            <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.214-1.832-2.148-4.032-2.687-5.886H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.498H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/>
            </svg>
            Upwork
          </a>
          <a
            href={`https://api.rafaelortiz.dev/cv?lang=${locale}`}
            target="_blank"
            rel="noopener noreferrer"
            class="card group flex items-center justify-center gap-2.5 px-4 py-4 text-sm font-medium text-[var(--color-fg-muted)] hover:text-[var(--color-accent)]"
          >
            <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            {locale === 'es' ? 'CV en vivo' : 'Live CV'}
          </a>
        </div>
      </div>

      <!-- Location -->
      <p class="mt-10 text-center text-sm text-[var(--color-fg-faint)]">
        {profile.location.city}, {profile.location.country} &middot; UTC-4
        <br />
        <span class="text-xs">
          {locale === 'es'
            ? 'Cómodo en zonas horarias US/EU'
            : 'Comfortable across US/EU time zones'}
        </span>
      </p>
    </div>
  </section>
</BaseLayout>
