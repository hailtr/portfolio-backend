---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Rafael Ortiz" description="Page not found">
  <section class="flex min-h-[60vh] items-center justify-center pt-28 pb-20">
    <div class="text-center px-[var(--container-px)]">
      <p class="metric text-6xl">404</p>
      <h1 class="mt-4 text-2xl font-bold tracking-tight">
        Page not found
      </h1>
      <p class="mt-2 text-[var(--color-fg-muted)]">
        The page you're looking for doesn't exist or has moved.
      </p>
      <a
        href="/"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--color-bg)] transition-all hover:brightness-110"
      >
        Go home
      </a>
    </div>
  </section>
</BaseLayout>
